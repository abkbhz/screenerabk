# ---------------------------------------------------------------------------
# BACKEND (server.ts — deployed to Render)
# ---------------------------------------------------------------------------

# GEMINI_API_KEY: Required for Gemini AI analysis.
# Get a free key at https://aistudio.google.com/apikey (see DEPLOY.md).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GEMINI_MODEL: Optional. Defaults to gemini-3.5-flash.
GEMINI_MODEL="gemini-3.5-flash"

# FRONTEND_ORIGIN: Allowed CORS origin for the frontend.
# Use "*" while testing; set to your Vercel URL in production,
# e.g. https://abk-screener.vercel.app
FRONTEND_ORIGIN="*"

# PORT: Injected automatically by Render. Only set locally if needed.
# PORT=3000

# ---------------------------------------------------------------------------
# FRONTEND (Vite — deployed to Vercel)
# ---------------------------------------------------------------------------

# VITE_API_BASE: The backend base URL the frontend calls.
# Leave EMPTY for local dev (same-origin). In Vercel, set this to your
# Render backend URL, e.g. https://abk-screener-api.onrender.com
VITE_API_BASE=""
